{
    "contractName": "uds.ai.figma-make",
    "schemaVersion": "1.0.0",
    "package": "@mich8060/unified-design-system",
    "scope": "Figma Make to UDS generation",
    "outputFormat": "json-tree",
    "principles": [
        "Token-driven styling with governed UDS tokens.",
        "No Tailwind utilities or className-based utility styling.",
        "Use governed component composition rules and layout templates.",
        "Load icon options from the UDS icon catalog before assigning icon props."
    ],
    "hardConstraints": {
        "allowedImports": [
            "@mich8060/unified-design-system",
            "@mich8060/unified-design-system/figma-make"
        ],
        "importRules": {
            "allowPackageLevelImportsOnly": true,
            "disallowDeepComponentImports": true
        },
        "disallowedPatterns": [
            "tailwind-utility-class",
            "className-utility-styling",
            "custom-css-variable",
            "raw-html-layout-wrapper"
        ],
        "styling": {
            "allowedVariableNamespace": "--uds-*",
            "allowHardcodedLiterals": true,
            "spacingPropsMustUseUDSSpacingToken": true
        },
        "layoutGovernance": {
            "useAppShellForRootLayout": true,
            "maxPrimaryActionsPerSection": 1
        },
        "forbiddenPropsByComponent": {
            "Menu": ["items", "selectedKeys", "mode"],
            "Flex": ["vertical", "justify", "align"],
            "Text": ["type", "strong"],
            "Button": ["type"],
            "Badge": ["status", "color"],
            "Statistics": ["title", "prefix", "suffix", "valueStyle"]
        }
    },
    "componentContracts": {
        "AppShell": {
            "import": "@mich8060/unified-design-system",
            "compoundSlots": [
                "Menu",
                "Content",
                "Listview",
                "Main",
                "SidePanel",
                "Footer"
            ],
            "namedSlots": [
                "Header",
                "Sidebar",
                "Breadcrumb",
                "Footer",
                "SubNav"
            ],
            "requiredProps": {
                "brand": "connect|comphealth|locumsmart|default|weatherby|modio|gms|chg|wireframe",
                "theme": "light|dark"
            }
        },
        "Menu": {
            "requiredProps": [
                "navItems"
            ],
            "optionalProps": [
                "activeBrand",
                "brands",
                "showBrandSwitcher",
                "showModeToggle",
                "showSearch",
                "accountMenuItems",
                "activeMode",
                "onBrandChange",
                "onModeChange"
            ],
            "iconInput": "Phosphor icon string names only",
            "defaults": {
                "showSearch": false,
                "accountMenuItems": [
                    { "label": "Contact", "icon": "Phone" },
                    { "label": "Feedback", "icon": "ChatCenteredText" },
                    { "label": "Sign out", "icon": "SignOut", "destructive": true }
                ]
            }
        },
        "Badge": {
            "variant": [
                "blue",
                "cyan",
                "green",
                "magenta",
                "indigo",
                "rose",
                "neutral",
                "orange",
                "purple",
                "red",
                "sky",
                "yellow",
                "inverse",
                "lime"
            ],
            "appearance": [
                "solid",
                "outlined"
            ]
        },
        "Button": {
            "appearance": [
                "primary",
                "soft",
                "outline",
                "text",
                "ghost",
                "destructive"
            ],
            "size": [
                "large",
                "default",
                "small",
                "xsmall"
            ],
            "icon": "Phosphor icon string name"
        },
        "Avatar": {
            "size": [
                "small",
                "default",
                "large"
            ],
            "initials": "2-character string"
        },
        "Text": {
            "variantFamilies": [
                "display-*",
                "heading-*",
                "body-*"
            ],
            "weight": [
                "regular",
                "medium",
                "semibold",
                "bold"
            ],
            "leading": [
                "tight",
                "regular",
                "loose"
            ]
        },
        "Flex": {
            "direction": [
                "row",
                "column"
            ],
            "justifyContent": [
                "flex-start",
                "center",
                "flex-end",
                "space-between",
                "space-around",
                "space-evenly"
            ],
            "alignItems": [
                "stretch",
                "flex-start",
                "center",
                "flex-end",
                "baseline"
            ],
            "gapRule": "Use --uds-spacing-* token values only."
        }
    },
    "navigationLogic": {
        "router": "react-router-dom (^6.26.2 || ^7.0.0)",
        "rootLayoutPattern": "AppShell with route outlet in AppShell.Main (optional AppShell.Listview and AppShell.SidePanel rails)"
    },
    "iconMappings": {
        "dashboard": "House",
        "requests": "ClipboardText",
        "providers": "Users",
        "calendar": "CalendarBlank",
        "invoices": "FileText",
        "reporting": "ChartBar"
    },
    "references": {
        "manifest": "@mich8060/unified-design-system/ai/manifest.json",
        "schema": "@mich8060/unified-design-system/ai/schema",
        "icons": "@mich8060/unified-design-system/ai/icons",
        "iconsJson": "@mich8060/unified-design-system/ai/icons.json",
        "templates": "@mich8060/unified-design-system/ai/templates",
        "validation": "@mich8060/unified-design-system/ai/validation",
        "adapter": "@mich8060/unified-design-system/figma-make"
    }
}
